# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log
storybook-static

# Private founder source files
/private/*
!/private/README.md

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Founder operational output (runtime data and incident snapshots are managed separately)
/private/founder/logs/
/private/founder/tmp/
/private/founder/operations/

# Transitional protection for legacy root-level operational logs
/controlled-restart*.log
/daily-briefing-lifecycle-*.log
/final-controlled-restart*.log
/final-restoration*.log
/founder-alpha-resume*.log
/log-evidence-cleanup*.log
/pending-review-reprocess*.log
/tmp-*.log
/debug.log
/storybook.log
/.clean-dev*.log
/.dev-server*.log
/.ngrok*.log
